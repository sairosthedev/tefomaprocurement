# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/fossil-procure

# Auth
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Branding (Tefoma)
COMPANY_NAME=Tefoma Construction
PRODUCT_NAME=Tefoma Procurement
EMAIL_FROM=Tefoma Procurement <notifications@miccstechnologies.co.zw>

# Front-end URL (used in email links and CORS). Production: your Vercel client URL, e.g. https://tefomaprocurement.vercel.app
CLIENT_URL=http://localhost:5173

# Extra allowed browser origins (comma-separated), e.g. preview deployments
# CORS_ORIGINS=https://tefomaprocurement.vercel.app

# Scheduled alerts (low stock, RFQ deadlines)
ALERT_JOBS_ENABLED=true
ALERT_JOBS_INTERVAL_MS=3600000
ALERT_DEDUP_HOURS=24
RFQ_DEADLINE_ALERT_HOURS=48
LOW_STOCK_DEFAULT_THRESHOLD=5
