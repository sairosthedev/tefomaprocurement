{
  "name": "api",
  "version": "1.0.0",
  "description": "Express API for FosssilProcure",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed.ts",
    "migrate:sites": "tsx src/scripts/migrate-sites.ts"
  },
  "dependencies": {
    "@fosssil/shared": "*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "multer": "^2.0.2",
    "pdfkit": "^0.17.2",
    "resend": "^3.5.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.13.4",
    "@types/validator": "^13.12.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
