{
  "version": 2,
  "installCommand": "cd .. && npm install && npm run build -w @fosssil/shared && npm run build -w api",
  "builds": [
    {
      "src": "dist/vercel.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**", "node_modules/@fosssil/**"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/dist/vercel.js" }]
}
