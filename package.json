{
  "name": "fosssil-procure",
  "version": "1.0.0",
  "description": "MERN stack monorepo for FosssilProcure",
  "private": true,
  "workspaces": [
    "api",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n api,client -c blue,magenta \"npm run dev -w api\" \"npm run dev -w client\"",
    "dev:api": "npm run dev -w api",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client",
    "start": "npm run start -w api",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

